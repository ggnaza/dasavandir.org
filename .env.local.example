# Copy this file to .env.local and fill in your values
# Get Supabase values from: https://supabase.com → your project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# Google OAuth (optional but recommended for SSO)
# 1. Create app at https://console.cloud.google.com
# 2. Set redirect URI to http://localhost:3000/auth/callback (local) and your-domain.com/auth/callback (prod)
# 3. Enable Google provider in Supabase: Auth → Providers → Google
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
