# Copy to .env.e2e and fill in values before running: npm run test:e2e
# Never commit .env.e2e — it contains real credentials.

# Base URL of the running app (local dev or staging)
E2E_BASE_URL=http://localhost:3000

# A real learner account in your Supabase DB (status=active, role=learner)
E2E_LEARNER_EMAIL=testlearner@example.com
E2E_LEARNER_PASSWORD=yourpassword

# A published course the learner IS enrolled in
E2E_COURSE_ID=uuid-here

# The first lesson of that course (learner has NOT completed it — for sequential gate test)
E2E_LESSON_ID=uuid-here

# The second lesson of that course (blocked until lesson 1 is done)
E2E_LESSON2_ID=uuid-here

# A published course the learner is NOT enrolled in
E2E_UNENROLLED_COURSE_ID=uuid-here
# Any lesson inside that course
E2E_UNENROLLED_LESSON_ID=uuid-here
